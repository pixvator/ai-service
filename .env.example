# Headless AI billing gateway minimum environment.
# Schema, channels, users, tokens, and runtime options are managed by the
# central new-api instance. This gateway only reads shared state and writes
# billing/log records.

# HTTP
PORT=3000
GIN_MODE=release

# Shared database. PostgreSQL is the intended deployment target for the
# headless gateway; the schema must already exist.
SQL_DSN=postgresql://newapi:change_me@127.0.0.1:5432/new-api

# Optional: use the same DB for logs by leaving this empty. Set it only when
# the central deployment uses a separate log database.
# LOG_SQL_DSN=postgresql://newapi:change_me@127.0.0.1:5432/new-api-log

# Redis is recommended because email verification codes and cache state must
# survive process restarts and multi-node deployments.
REDIS_CONN_STRING=redis://:change_me@127.0.0.1:6379/0
MEMORY_CACHE_ENABLED=true

# Secrets. CRYPTO_SECRET protects encrypted provider/channel secrets. Use the
# same value as the central new-api instance, otherwise existing encrypted rows
# cannot be read correctly.
CRYPTO_SECRET=replace_with_same_secret_as_central_new_api


# SMTP transport compatibility flags. SMTP server/account/from/token are
# system options loaded from the shared database and should be configured by
# the central new-api instance.
# SMTP_STARTTLS_ENABLE=true
# SMTP_INSECURE_SKIP_VERIFY=false
# SMTP_FORCE_AUTH_LOGIN=false

# OAuth callback URL base, Turnstile secret, GitHub client credentials, Discord
# settings, OIDC settings, and custom OAuth providers are also loaded from the
# shared system options/custom provider tables managed by the central instance.
# Make sure ServerAddress matches the redirect URI configured in each provider.

# Linux DO endpoint overrides are real environment variables. Client credentials
# are still shared system options.
# LINUX_DO_AUTHORIZATION_ENDPOINT=https://connect.linux.do/oauth2/authorize
# LINUX_DO_TOKEN_ENDPOINT=https://connect.linux.do/oauth2/token
# LINUX_DO_USER_ENDPOINT=https://connect.linux.do/api/user

# Optional debug/local development flags.
# DEBUG=true
# TLS_INSECURE_SKIP_VERIFY=false
# ERROR_LOG_ENABLED=true
